# Defaults for the Krafters QA executor (sourced by run.sh).
# Local dev-seed credentials — local Supabase only, no remote power.
# Override any of these inline:  QA_TARGET_PATH=/w/foo ./run.sh
export QA_EMAIL="${QA_EMAIL:-dev@krafters.local}"
export QA_PASSWORD="${QA_PASSWORD:-dev-password-123!}"
export QA_TARGET_PATH="${QA_TARGET_PATH:-/w/krafters-demo}"
export QA_TITLE="${QA_TITLE:-Krafters QA}"

# Where the krafters-admin app lives, used to boot a dev server when no
# QA_APP_ORIGIN is already running. Point this at the worktree under test.
export QA_APP_DIR="${QA_APP_DIR:-$HOME/projects/krafters/krafters-admin}"
